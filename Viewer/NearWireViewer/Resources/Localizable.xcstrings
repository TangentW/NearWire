            "state" : "translated",
            "value" : "Connection settings and live telemetry are available only while this Device is connected. Imported and recent offline Devices remain available for Event scope and read-only Session details."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "连接设置和实时遥测仅在设备连接期间可用。已导入和最近离线的设备仍可用于事件范围和只读会话详情。"
          }
        }
      }
    },
